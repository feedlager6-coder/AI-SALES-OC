# =============================================================================
# AI Sales OS — Environment Variables
# =============================================================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.
# =============================================================================

# --- Application ---
NODE_ENV=development
LOG_LEVEL=debug
PORT=3001

# --- Database (PostgreSQL 16) ---
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_sales_os

# --- Redis 7 ---
REDIS_URL=redis://localhost:6379

# --- Auth (Better Auth) ---
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=your-super-secret-key-min-32-chars-here
BETTER_AUTH_URL=http://localhost:3000

# --- API Key Encryption ---
# AES-256 key for encrypting workspace API keys at rest
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# =============================================================================
# External API Keys (optional — enable specific plugins)
# =============================================================================

# --- AI Providers ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# --- Email Sending ---
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

BREVO_API_KEY=

# --- Lead Sources ---
TWOGIS_API_KEY=

# --- Enrichment ---
HUNTER_API_KEY=
SNOV_API_KEY=
DADATA_API_KEY=

# --- Notifications ---
TELEGRAM_BOT_TOKEN=

# --- Storage (MinIO / S3) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ai-sales-os
MINIO_USE_SSL=false

# --- Frontend (public, safe to expose) ---
NEXT_PUBLIC_API_URL=http://localhost:3001
