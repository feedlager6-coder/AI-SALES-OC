modules = ["nodejs-20", "web", "bash", "nix"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/web && NEXT_PUBLIC_API_URL=\"\" pnpm dev --port 5000"
waitForPort = 5000

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "redis-server --daemonize yes --port 6379 --save '' --appendonly no > /tmp/redis.log 2>&1; sleep 1; cd apps/api && pnpm dev"
waitForPort = 3001

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 6379
externalPort = 3000

[userenv]

[userenv.shared]
BETTER_AUTH_URL = "http://localhost:3001"
LOG_LEVEL = "info"
NODE_ENV = "development"
REDIS_URL = "redis://localhost:6379"
BETTER_AUTH_SECRET = "f48a403738d99b56651381adfca5afccc2b6d564ac72f5cbd13ebf0af93f23cee40fb4a5f00c1385a3f61defc5790f1a"
ENCRYPTION_KEY = "10afcfbb0b9014ce32906b0b132ae0ff2149bf80527f5cca720d3a0cbfd4eda3"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
